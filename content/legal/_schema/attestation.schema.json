{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://klikk.co.za/schemas/legal/attestation.schema.json",
  "title": "Legal Attestation",
  "description": "An admitted-attorney attestation event covering a batch of legal facts. Append-only. See content/cto/centralised-legal-rag-store-plan.md §4.",
  "type": "object",
  "required": [
    "attestation_id",
    "attorney_name",
    "attorney_admission_number",
    "attestation_method",
    "attestation_date",
    "scope",
    "facts_attested"
  ],
  "additionalProperties": true,
  "properties": {
    "attestation_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$",
      "maxLength": 80,
      "description": "Stable id, e.g. '2026-Q2-attorney-review'."
    },
    "attorney_name": {
      "type": "string",
      "minLength": 1
    },
    "attorney_admission_number": {
      "type": "string",
      "minLength": 1,
      "description": "LPC admission number, e.g. 'LPC-WC-12345'."
    },
    "attorney_firm": {
      "type": "string"
    },
    "attestation_method": {
      "type": "string",
      "enum": [
        "email_pdf_signed",
        "in_person_review",
        "counsel_opinion_letter"
      ]
    },
    "attestation_date": {
      "type": "string",
      "format": "date"
    },
    "opinion_letter_pdf_sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "opinion_letter_storage": {
      "type": "string",
      "description": "Storage URI, e.g. 'vault33://klikk-internal/legal-attestations/2026-Q2.pdf'."
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "cost_zar": {
      "type": ["number", "integer"],
      "minimum": 0
    },
    "facts_attested": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["concept_id", "fact_version", "finding"],
        "additionalProperties": false,
        "properties": {
          "concept_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "fact_version": {
            "type": "integer",
            "minimum": 1
          },
          "finding": {
            "type": "string",
            "enum": ["confirmed", "corrected", "rejected"]
          },
          "correction_summary": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "description": "finding=corrected requires correction_summary.",
            "if": {
              "properties": { "finding": { "const": "corrected" } },
              "required": ["finding"]
            },
            "then": {
              "required": ["correction_summary"],
              "properties": {
                "correction_summary": { "type": "string", "minLength": 1 }
              }
            }
          }
        ]
      }
    }
  }
}
