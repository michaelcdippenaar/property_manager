# Copy to .env.development (not committed) for local development.
# Use the same OAuth client as backend GOOGLE_OAUTH_CLIENT_ID (Web client).
API_URL=http://localhost:8000/api/v1
# GOOGLE_CLIENT_ID=....apps.googleusercontent.com

# Dev login auto-fill (OPTIONAL)
# WARNING: Only set these if you have a non-production test account.
# NEVER commit real credentials to this file. Leave empty to disable auto-fill.
# VITE_DEV_LOGIN_EMAIL=
# VITE_DEV_LOGIN_PASSWORD=

# Live-reload on physical device (Capacitor native dev builds only)
# Set to the URL the device should load the Vite dev server from — typically your
# machine's LAN IP on the Vite port (e.g. http://192.168.1.10:5176).
# Capacitor reads this via server.url in capacitor.config.ts.
# DEV ONLY — must NOT be set in staging or production builds.
# CAPACITOR_SERVER_URL=http://<host-lan-ip>:5176

# Sentry — leave blank in dev (no events sent when DSN is absent)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# GIT_COMMIT=
# SENTRY_TRACES_SAMPLE_RATE=0.05
