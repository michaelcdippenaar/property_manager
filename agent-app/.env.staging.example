# Copy to .env.staging (not committed) for staging builds.
# GOOGLE_CLIENT_ID — injected at build time via CI secrets.
API_URL=https://backend.klikk.co.za/api/v1
# GOOGLE_CLIENT_ID=....apps.googleusercontent.com

# Sentry — set in CI environment secrets for staging
# SENTRY_DSN=https://<key>@oXXXXXX.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=staging
# GIT_COMMIT=<git-sha>
# SENTRY_TRACES_SAMPLE_RATE=0.05
