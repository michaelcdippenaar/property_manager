{
  "compilerOptions": {
    "module": "Preserve",
    "strict": true,
    "lib": ["es2022", "dom"],
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"],
      "app/*": ["./*"],
      "components/*": ["src/components/*"],
      "layouts/*": ["src/layouts/*"],
      "pages/*": ["src/pages/*"],
      "stores/*": ["src/stores/*"],
      "boot/*": ["src/boot/*"]
    }
  },
  "include": [
    "./**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.vue"
  ]
}
