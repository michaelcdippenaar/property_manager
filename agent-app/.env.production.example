# Copy to .env.production for Docker/production builds (not committed).
API_URL=https://backend.example.com/api/v1
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Sentry — required in production; set in CI environment secrets
# SENTRY_DSN=https://<key>@oXXXXXX.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=production
# GIT_COMMIT=<git-sha>  (injected by CI)
# SENTRY_TRACES_SAMPLE_RATE=0.05
