<?xml version="1.0" encoding="utf-8"?>
<!--
  Klikk Agent adaptive-icon foreground layer.
  Renders a white "K" monogram centred in the 108dp safe zone (72dp inner safe area).
  Background colour (Navy #2B2D6E) is set in values/ic_launcher_background.xml and
  drawable/ic_launcher_background.xml.
  Replace this file with the final vector artwork when supplied by the brand team.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Vertical stem of K (x 38–48, y 22–86) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M38,22 L48,22 L48,86 L38,86 Z" />

    <!-- Upper arm of K: from junction (48,54) to top-right (80,22) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M46,54 L80,22 L88,22 L54,54 Z" />

    <!-- Lower arm of K: from junction (48,54) to bottom-right (80,86) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M46,54 L54,54 L88,86 L80,86 Z" />

</vector>
