# keystore.properties — Android release signing credentials
#
# Copy this file to keystore.properties (same directory) and fill in real values.
# keystore.properties must NEVER be committed to source control (it is in .gitignore).
#
# For CI/CD (GitHub Actions), each secret is stored in the repository's encrypted
# secrets and written to keystore.properties at build time by the release workflow.
# See agent-app/docs/android-signing.md for the full keytool / upload key guide.

# Path to the .jks / .keystore file, relative to this android/ directory.
# Example: ../klikk-agent-release.jks
storeFile=REPLACE_WITH_KEYSTORE_PATH

# Password that was set when the keystore was created with keytool.
storePassword=REPLACE_WITH_STORE_PASSWORD

# The alias name chosen during keytool -genkey.
keyAlias=REPLACE_WITH_KEY_ALIAS

# Password for the specific key entry (often the same as storePassword).
keyPassword=REPLACE_WITH_KEY_PASSWORD
