VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000
# VITE_GOOGLE_CLIENT_ID and VITE_GOOGLE_MAPS_KEY — copy from .env.secrets (never commit real values)
VITE_SELF_SIGNUP=true
# AI Guide widget — set to 'true' to enable the floating guide agent (default: off)
VITE_ENABLE_AI_GUIDE=false
