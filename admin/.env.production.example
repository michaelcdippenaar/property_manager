# Copy to .env.production for Docker/production builds (not committed).
VITE_API_URL=https://backend.example.com/api/v1
VITE_WS_URL=wss://backend.example.com
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_MAPS_KEY=your-maps-key
VITE_SELF_SIGNUP=false

# Plausible Analytics — set to the hostname registered in Plausible for the
# admin app. When present, the SPA loads the self-hosted plausible.js script
# and tracks pageviews + named conversion events. Leave unset in dev/staging
# unless you want events flowing to the analytics instance.
VITE_PLAUSIBLE_DOMAIN=app.klikk.co.za

# Sentry — required in production; set in CI environment secrets
# VITE_SENTRY_DSN=https://<key>@oXXXXXX.ingest.sentry.io/<project>
# VITE_SENTRY_ENVIRONMENT=production
# VITE_APP_RELEASE=<git-sha>  (injected by CI via GIT_COMMIT)
# SENTRY_AUTH_TOKEN=<token>   (CI secret — used by @sentry/vite-plugin to upload source maps)
# SENTRY_ORG=klikk
# SENTRY_PROJECT_ADMIN=klikk-admin
