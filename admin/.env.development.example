# Copy to .env.development.local (not committed) for Google Sign-In on localhost.
# Use the same OAuth client as backend GOOGLE_OAUTH_CLIENT_ID (Web client).
# VITE_GOOGLE_CLIENT_ID=....apps.googleusercontent.com

# Sentry — leave blank in dev (no events sent when DSN is absent)
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=development
# VITE_APP_RELEASE=

# AI Guide widget — set to 'true' to enable the floating guide agent (default: off)
# VITE_ENABLE_AI_GUIDE=false

# Plausible Analytics — leave unset in dev (no script injected when absent)
# Uncomment to test against a local/staging Plausible instance.
# VITE_PLAUSIBLE_DOMAIN=app.klikk.co.za
