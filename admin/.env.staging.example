# Copy to .env.staging (not committed) for staging builds.
# VITE_GOOGLE_CLIENT_ID and VITE_GOOGLE_MAPS_KEY — injected at build time via CI secrets.
VITE_API_URL=https://backend.klikk.co.za/api/v1
VITE_WS_URL=wss://backend.klikk.co.za
VITE_SELF_SIGNUP=false

# AI Guide — slide-in chat assistant. Must be 'true' (string) to render the
# floating Sparkles FAB and panel; anything else hides the widget and shows
# the static fallback link to /property-info/agent. Bake-in at build time.
VITE_ENABLE_AI_GUIDE=true

# Sentry — set in CI environment secrets for staging
# VITE_SENTRY_DSN=https://<key>@oXXXXXX.ingest.sentry.io/<project>
# VITE_SENTRY_ENVIRONMENT=staging
# VITE_APP_RELEASE=<git-sha>

# Microsoft Clarity session recording — ONLY enabled on staging and production.
# Leave unset (or set to false) in dev and CI to prevent recording test sessions.
# Create a Clarity project at https://clarity.microsoft.com and paste the project ID below.
VITE_ENABLE_CLARITY=true
VITE_CLARITY_PROJECT_ID=<your-clarity-project-id>
