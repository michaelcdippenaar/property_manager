# Secrets — actual .env files with real values are never committed
# Template files (.env.development, .env.staging, .env.production) ARE committed
.env
.env.local
*.pem
*.dump
.secrets/
client_secret*.json

# Python
backend/.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# Django
backend/staticfiles/
backend/media/
backend/documents/
backend/rag_chroma/
*.sqlite3

# Node / frontend
admin/node_modules/
admin/dist/
services/**/node_modules/

# Local / tooling (do not commit)
# Claude Code: commit skills + shared JSON; keep machine-only and heavy dirs out
.claude/worktrees/
.claude/old/
.claude/docuseal/
.claude/settings.local.json
flutter_logs.txt

# Playwright (local)
admin/test-results/

# Flutter / Dart
mobile/.dart_tool/
mobile/build/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies

# OS / editor
.DS_Store
.idea/
*.swp
*.swo

# Agent app / tenant web (Quasar/Vite)
agent-app/node_modules/
tenant/node_modules/
agent-app/dist/
tenant/dist/
agent-app/.quasar/
tenant/.quasar/

# Tenant app (Quasar monorepo folder)
tenant-app/node_modules/
tenant-app/dist/
tenant-app/.quasar/

# Capacitor iOS — local Xcode build artefacts (do not commit)
agent-app/ios/App/DerivedData/
agent-app/ios/App/build/
tenant-app/ios/DerivedData/
tenant-app/ios/App/build/

# Capacitor web asset dir (has its own node_modules + Xcode DerivedData when synced)
agent-app/src-capacitor/node_modules/
agent-app/src-capacitor/ios/DerivedData/
agent-app/src-capacitor/ios/**/build/
