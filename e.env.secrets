# Mirrors docker-compose.yml environment (single source of truth for local compose).
# Postgres — db service
POSTGRES_DB=klikk_db
POSTGRES_USER=klikk_user
POSTGRES_PASSWORD=klikk_pass

# Backend — backend service (hostname `db` is correct inside Docker network)
DATABASE_URL=postgres://klikk_user:klikk_pass@db:5432/klikk_db
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Admin — admin service
VITE_API_URL=http://localhost:8000/api/v1
