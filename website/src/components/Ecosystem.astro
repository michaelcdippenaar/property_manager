---
/**
 * Ecosystem — "One Platform, Four Apps" section
 *
 * Dark background section showcasing the 4 Klikk apps.
 * Each card has a unique color-coded icon (Lucide SVG).
 * Static content — doesn't read from YAML.
 */

const apps = [
  {
    name: 'Klikk Admin',
    desc: 'Command centre for your portfolio. AI leases, maintenance dispatch, supplier matching, e-signing — all in one dashboard.',
    platform: 'Web App',
    iconClass: 'admin',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="#FF3D7F" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
  },
  {
    name: 'Klikk Tenant',
    desc: 'Report issues with photos, chat in real-time, view lease details, and sign documents — all from their phone.',
    platform: 'iOS & Android',
    iconClass: 'tenant',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18.01"/></svg>`,
  },
  {
    name: 'Klikk Owner',
    desc: 'Real-time portfolio visibility. Occupancy rates, income tracking, maintenance status, and lease pipeline at a glance.',
    platform: 'Web Portal',
    iconClass: 'owner',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    name: 'Klikk Supplier',
    desc: 'Receive jobs, submit quotes, manage your calendar. No login required for quoting — just click the link.',
    platform: 'Web Portal',
    iconClass: 'supplier',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  },
];
---

<section class="section-dark" id="apps">
  <div class="section-inner">
    <div class="section-label reveal">One Platform, Four Apps</div>
    <div class="section-title reveal reveal-delay-1">Every person gets<br>their own experience.</div>
    <div class="section-desc reveal reveal-delay-2">Purpose-built apps for agents, tenants, owners, and suppliers. Connected in real-time. One source of truth.</div>

    <div class="eco-grid">
      {apps.map((app, i) => (
        <div class={`eco-card reveal eco-${app.iconClass}`} style={`--i: ${i}`}>
          <div class={`eco-icon ${app.iconClass}`}>
            <Fragment set:html={app.icon} />
          </div>
          <div class="eco-text">
            <h3>{app.name}</h3>
            <p>{app.desc}</p>
            <div class="platform">&#9679; {app.platform}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-dark {
    background: #faf9f7;
    color: var(--color-navy);
    max-width: 100%;
    position: relative;
    overflow: hidden;
  }
  .section-inner {
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    padding: 120px 48px;
  }
  .section-dark .section-label { color: var(--color-accent); }
  .section-dark .section-title { color: var(--color-navy); }
  .section-dark .section-desc { color: #6b7280; }

  .eco-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 20px;
    align-items: stretch;
  }
  /* Bento: Admin featured left (tall), others right */
  .eco-admin { grid-column: 1; grid-row: 1 / 3; }
  .eco-tenant { grid-column: 2; grid-row: 1; }
  .eco-owner  { grid-column: 3; grid-row: 1; }
  .eco-supplier { grid-column: 2 / 4; grid-row: 2; }

  .eco-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 20px;
    padding: 32px 28px;
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .eco-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 20px;
    opacity: 0;
    transition: opacity 0.35s;
    box-shadow: inset 0 0 0 1.5px rgba(43,45,110,0.2);
  }
  .eco-card:hover { box-shadow: 0 12px 40px rgba(43,45,110,0.1); transform: translateY(-3px); }
  .eco-card:hover::after { opacity: 1; }

  .eco-card.reveal {
    transition-delay: calc(var(--i, 0) * 80ms);
  }

  /* Admin card gets a subtle background gradient */
  .eco-admin {
    background: linear-gradient(160deg, #ffffff 60%, rgba(43,45,110,0.03) 100%);
  }
  /* Supplier card: horizontal layout */
  .eco-supplier {
    flex-direction: row;
    align-items: center;
    gap: 28px;
  }
  .eco-supplier .eco-icon { margin-bottom: 0; flex-shrink: 0; }
  .eco-supplier .eco-text { flex: 1; }
  .eco-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }
  .eco-icon :global(svg) { width: 24px; height: 24px; stroke-width: 1.75; }
  .eco-icon.admin { background: rgba(255,61,127,0.1); color: var(--color-accent); }
  .eco-icon.tenant { background: rgba(16,185,129,0.1); color: #10b981; }
  .eco-icon.owner { background: rgba(59,130,246,0.1); color: #3b82f6; }
  .eco-icon.supplier { background: rgba(245,158,11,0.1); color: #f59e0b; }
  .eco-text { display: flex; flex-direction: column; flex: 1; }
  .eco-card h3 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 8px;
    letter-spacing: -0.3px;
  }
  .eco-admin h3 { font-size: 24px; }
  .eco-card p {
    font-size: 14px;
    line-height: 1.6;
    color: #6b7280;
    flex: 1;
  }
  .platform {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9ca3af;
    margin-top: 16px;
  }

  @media (max-width: 1024px) {
    .eco-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto auto auto; }
    .eco-admin { grid-column: 1 / 3; grid-row: 1; }
    .eco-tenant { grid-column: 1; grid-row: 2; }
    .eco-owner  { grid-column: 2; grid-row: 2; }
    .eco-supplier { grid-column: 1 / 3; grid-row: 3; }
  }
  @media (max-width: 640px) {
    .section-inner { padding: 80px 20px; }
    .eco-grid { grid-template-columns: 1fr; grid-template-rows: unset; }
    .eco-admin, .eco-tenant, .eco-owner, .eco-supplier { grid-column: 1; grid-row: auto; }
    .eco-supplier { flex-direction: column; }
  }
</style>
