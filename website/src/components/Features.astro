---
/**
 * Features — AI-powered feature cards (homepage section)
 *
 * DATA-DRIVEN: Reads features with show_on_homepage=true
 * from content/product/features.yaml via the content loader.
 */
import { getFeatures, statusBadge } from '../lib/content';

// Only the 6 features tagged homepage_section: features
const features = Object.values(getFeatures()).filter(f => f.homepage_section === 'features');

const iconSvgs: Record<string, string> = {
  'file-text': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  'search-plus': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/><line x1="11" y1="8" x2="11" y2="14"/></svg>`,
  'user-plus': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>`,
  'pen': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  'pen-tool': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`,
  'message-square': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  'bar-chart': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  'bar-chart-2': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  'wrench': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  'smartphone': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18.01"/></svg>`,
  'home': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  'shield': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  'bell': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`,
  'zap': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  'layers': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
  'plug': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8H6a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2z"/></svg>`,
  'circle': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>`,
};

// Icon background colors cycle through brand palette
const iconColors = [
  { bg: 'rgba(43,45,110,0.08)', color: '#2B2D6E' },
  { bg: 'rgba(255,61,127,0.08)', color: '#FF3D7F' },
  { bg: 'rgba(16,185,129,0.08)', color: '#10b981' },
  { bg: 'rgba(59,130,246,0.08)', color: '#3b82f6' },
  { bg: 'rgba(245,158,11,0.08)', color: '#f59e0b' },
  { bg: 'rgba(139,92,246,0.08)', color: '#8b5cf6' },
];
---

<section class="features-section" id="features">
  <div class="features-inner">
    <div class="features-header">
      <div class="section-label reveal">AI-Powered Features</div>
      <h2 class="section-title reveal reveal-delay-1">Intelligence baked into<br>every workflow.</h2>
      <p class="section-desc reveal reveal-delay-2">Not just automation. Actual intelligence that understands South African rental law, supplier proximity, and lease compliance.</p>
    </div>

    <div class="features-grid">
      {features.map((feature, i) => {
        const color = iconColors[i % iconColors.length];
        const badge = statusBadge(feature.status);
        return (
          <div class="feature-card reveal" style={`--i: ${i}`}>
            <div class="feature-icon" style={`background: ${color.bg};`}>
              <span style={`color: ${color.color};`}>
                <Fragment set:html={iconSvgs[feature.icon] || iconSvgs['circle']} />
              </span>
            </div>
            <h3>{feature.headline}</h3>
            <p>{feature.description}</p>
            <div class="feature-footer">
              <span class={`feature-badge ${badge.class}`}>{badge.label}</span>
              <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .features-section {
    background: #faf9f7;
    padding: 0;
  }
  .features-inner {
    max-width: 1260px;
    margin: 0 auto;
    padding: 100px 40px;
  }
  .features-header {
    max-width: 560px;
    margin-bottom: 56px;
  }
  .features-header .section-label { color: var(--color-accent); }
  .features-header .section-title { color: var(--color-navy); }
  .features-header .section-desc { color: #6b7280; }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .feature-card {
    background: #1a1b4b;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px;
    padding: 28px;
    transition: all 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    overflow: hidden;
  }
  .feature-card.reveal {
    transition-delay: calc(var(--i, 0) * 70ms);
  }
  .feature-card:hover {
    background: #22246a;
    border-color: rgba(255,255,255,0.14);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(26,27,75,0.35);
  }
  .feature-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .feature-icon :global(svg) {
    width: 20px; height: 20px;
    stroke-width: 1.75;
  }
  .feature-card h3 {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: white;
    letter-spacing: -0.3px;
    line-height: 1.3;
  }
  .feature-card p {
    font-size: 13.5px;
    line-height: 1.65;
    color: rgba(255,255,255,0.45);
    flex: 1;
  }
  .feature-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 4px;
  }
  .feature-badge {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 8px;
    border-radius: 6px;
  }
  .feature-badge.built { background: rgba(16,185,129,0.15); color: #34d399; }
  .feature-badge.planned { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.3); }
  .feature-badge.in-progress { background: rgba(245,158,11,0.15); color: #fbbf24; }
  .feature-badge.beta { background: rgba(37,99,235,0.15); color: #60a5fa; }
  .arrow {
    color: rgba(255,255,255,0.2);
    transition: color 0.2s, transform 0.2s;
  }
  .feature-card:hover .arrow { color: var(--color-accent); transform: translateX(3px); }

  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .features-inner { padding: 72px 24px; }
    .features-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .features-inner { padding: 72px 24px; }
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
