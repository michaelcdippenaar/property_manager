---
/**
 * Lifecycle — 15-stage rental lifecycle grid
 * DATA-DRIVEN: status from content/product/lifecycle.yaml → features.yaml
 */
import { getLifecycle, statusBadge } from '../lib/content';
const steps = getLifecycle();

const phases = [
  { label: 'Find & Onboard', steps: [1,2,3,4,5,6] },
  { label: 'Move In', steps: [7,8] },
  { label: 'Live & Manage', steps: [9,10,11,12] },
  { label: 'Move Out', steps: [13,14,15] },
];
---

<section class="lifecycle-section" id="lifecycle">
  <div class="lifecycle-inner">
    <div class="lifecycle-header">
      <div class="section-label reveal">The Complete Rental Journey</div>
      <h2 class="section-title reveal reveal-delay-1">From advertising to deposit refund.<br>Every stage, one platform.</h2>
      <p class="section-desc reveal reveal-delay-2">Klikk covers the entire tenant lifecycle — no gaps, no workarounds, no spreadsheets.</p>
    </div>

    <div class="lifecycle-grid">
      {steps.map(step => {
        const badge = statusBadge(step.status);
        const isBuilt = step.status === 'BUILT' || step.status === 'BETA';
        return (
          <div class={`lifecycle-step reveal ${badge.class}`} style={`--i: ${step.step - 1}`}>
            <div class="step-num">{String(step.step).padStart(2, '0')}</div>
            <div class="step-body">
              <div class="step-title">{step.title}</div>
              <div class="step-desc">{step.description}</div>
            </div>
            <div class={`step-status ${badge.class}`}>
              {isBuilt
                ? <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                : <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12" y2="16"/></svg>
              }
              {badge.label}
            </div>
          </div>
        );
      })}
    </div>

    <div class="lifecycle-footer reveal">
      <span class="legend-item"><span class="legend-dot built"></span>Live in Klikk</span>
      <span class="legend-divider">·</span>
      <span class="legend-item"><span class="legend-dot planned"></span>Coming soon</span>
      <span class="legend-divider">·</span>
      <span class="legend-count"><strong>15</strong> stages covered end-to-end</span>
    </div>
  </div>
</section>

<style>
  .lifecycle-section {
    background: #0f1038;
    position: relative;
    overflow: hidden;
  }
  .lifecycle-section::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,61,127,0.07) 0%, transparent 65%);
    pointer-events: none;
  }
  .lifecycle-inner {
    max-width: 1260px;
    margin: 0 auto;
    padding: 100px 40px;
    position: relative;
    z-index: 2;
  }
  .lifecycle-header {
    max-width: 640px;
    margin-bottom: 56px;
  }
  .lifecycle-header .section-label {
    color: var(--color-accent);
    opacity: 0.85;
  }
  .lifecycle-header .section-title {
    color: white;
  }
  .lifecycle-header .section-desc {
    color: rgba(255,255,255,0.5);
  }

  /* Grid */
  .lifecycle-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2px;
    margin-bottom: 40px;
  }

  .lifecycle-step {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 20px 18px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: background 0.25s, border-color 0.25s, transform 0.25s;
    cursor: default;
  }
  .lifecycle-step.reveal {
    transition-delay: calc(var(--i, 0) * 40ms);
  }
  .lifecycle-step:hover {
    background: rgba(255,255,255,0.07);
    border-color: rgba(255,255,255,0.12);
    transform: translateY(-2px);
  }
  .lifecycle-step.built {
    background: rgba(16,185,129,0.07);
    border-color: rgba(16,185,129,0.18);
  }
  .lifecycle-step.built:hover {
    background: rgba(16,185,129,0.11);
    border-color: rgba(16,185,129,0.28);
  }

  .step-num {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -2px;
    line-height: 1;
    color: rgba(255,255,255,0.1);
  }
  .lifecycle-step.built .step-num {
    color: rgba(16,185,129,0.25);
  }

  .step-body { flex: 1; }
  .step-title {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: white;
    margin-bottom: 5px;
    letter-spacing: -0.2px;
    line-height: 1.3;
  }
  .lifecycle-step:not(.built) .step-title {
    color: rgba(255,255,255,0.65);
  }
  .step-desc {
    font-size: 11.5px;
    line-height: 1.55;
    color: rgba(255,255,255,0.35);
  }
  .lifecycle-step.built .step-desc {
    color: rgba(255,255,255,0.5);
  }

  .step-status {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 8px;
    border-radius: 6px;
    align-self: flex-start;
  }
  .step-status.built { background: rgba(16,185,129,0.15); color: #34d399; }
  .step-status.beta { background: rgba(37,99,235,0.15); color: #60a5fa; }
  .step-status.planned { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.3); }
  .step-status.in-progress { background: rgba(245,158,11,0.15); color: #fbbf24; }

  /* Footer */
  .lifecycle-footer {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    font-weight: 500;
  }
  .legend-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
  }
  .legend-dot.built { background: #34d399; }
  .legend-dot.planned { background: rgba(255,255,255,0.2); }
  .legend-divider { color: rgba(255,255,255,0.15); }
  .legend-count {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
  }
  .legend-count strong {
    color: rgba(255,255,255,0.7);
    font-weight: 700;
  }

  @media (max-width: 1024px) {
    .lifecycle-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 640px) {
    .lifecycle-inner { padding: 72px 24px; }
    .lifecycle-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
