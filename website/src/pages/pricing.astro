---
/**
 * Pricing page — 4-tier per-organisation model (Free / Pro / Agency / Enterprise)
 * DATA-DRIVEN: reads from content/product/pricing.yaml
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import yaml from 'js-yaml';
import fs from 'fs';
import path from 'path';

const CONTENT_DIR = path.resolve(process.cwd(), '../content');
const raw = fs.readFileSync(path.join(CONTENT_DIR, 'product/pricing.yaml'), 'utf8');
const data = yaml.load(raw) as any;
const tiers = Object.values(data.tiers) as any[];
const roles = (data.user_roles ?? []) as any[];
const addons = (data.platform_addons ?? []) as any[];
const allInclude: string[] = data.all_plans_include;
const registerUrl = import.meta.env.PUBLIC_REGISTER_URL ?? 'https://register.klikk.co.za';
const contactUrl = import.meta.env.PUBLIC_CONTACT_URL ?? 'https://klikk.co.za/contact';
---

<BaseLayout
  title="Pricing — Klikk Property Management"
  description="Start free with 5 properties and full AI (bring your own key). Pro R2,500/mo (50 props/100 units), Agency R4,000/mo (100 props/200 units). Enterprise with white-labelling and on-premises hosting."
>
  <div class="pricing-page">

    <!-- Header -->
    <div class="pricing-hero reveal">
      <div class="section-label">Pricing</div>
      <h1>Simple pricing.<br/>Scales with your portfolio.</h1>
      <p>Start free. No credit card. Upgrade when your portfolio grows.</p>
    </div>

    <!-- All plans include -->
    <div class="all-include reveal reveal-delay-1">
      <span class="all-label">All plans include:</span>
      {allInclude.map(item => (
        <span class="all-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          {item}
        </span>
      ))}
    </div>

    <!-- Tier cards — 4-column grid -->
    <div class="tiers-grid tiers-grid-4">
      {tiers.map((tier, i) => (
        <div class={`tier-card reveal${tier.highlight ? ' tier-highlight' : ''}${tier.name === 'Enterprise' ? ' tier-enterprise' : ''}${tier.name === 'Custom' ? ' tier-custom' : ''}`} style={`transition-delay: ${i * 0.08}s`}>
          {tier.highlight && <div class="popular-badge">Most Popular</div>}

          <div class="tier-top">
            <div class="tier-name">{tier.name}</div>
            <div class="tier-subtitle">{tier.subtitle}</div>

            <!-- Price -->
            <div class="tier-price">
              {tier.price_monthly === 0
                ? <><span class="price-amount">Free</span><span class="price-sub">forever</span></>
                : tier.price_monthly === null
                  ? <><span class="price-amount">POA</span><span class="price-sub">on application</span></>
                  : <><span class="price-amount">R{tier.price_monthly.toLocaleString('en-ZA')}</span><span class="price-sub">/mo</span></>
              }
            </div>

            <!-- Enterprise per-property note -->
            {tier.price_per_property && (
              <div class="per-property-note">
                + R{tier.price_per_property}/property above 100
              </div>
            )}

            <!-- Meta pills: properties / units / users -->
            <div class="tier-meta">
              <span class="tier-meta-pill">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                {tier.properties} prop{tier.units ? `s / ${tier.units} units` : 's'}
              </span>
              <span class="tier-meta-pill">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                {tier.users_included} user
              </span>
              {/* BYOK badge for free tier */}
              {tier.llm_key === 'bring_your_own' && (
                <span class="tier-meta-pill tier-meta-pill-byok">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
                  Own LLM key
                </span>
              )}
            </div>

            <!-- Enterprise badges -->
            {(tier.name === 'Enterprise' || tier.name === 'Custom') && (
              <div class="enterprise-badges">
                <span class={tier.name === 'Custom' ? 'ent-badge ent-badge-custom' : 'ent-badge'}><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>White-label</span>
                <span class={tier.name === 'Custom' ? 'ent-badge ent-badge-custom' : 'ent-badge'}><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/></svg>On/off premises</span>
                {tier.name === 'Custom' && <span class="ent-badge ent-badge-custom"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>BI + ETL</span>}
                {tier.name !== 'Custom' && <span class="ent-badge"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>POPIA storage</span>}
              </div>
            )}

            <!-- Free tier: optional add-ons + marketplace credits note -->
            {tier.name === 'Free' && (
              <div class="free-addons-note">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Vetting &amp; Marketplace available as optional extras. Marketplace profits returned as cash or credits.
              </div>
            )}
          </div>

          {/* Custom tier — pillar cards before feature list */}
          {tier.name === 'Custom' && tier.custom_pillars && (
            <div class="custom-pillars">
              {(tier.custom_pillars as any[]).map((p: any) => (
                <div class="custom-pillar">
                  <div class="custom-pillar-label">{p.label}</div>
                  <div class="custom-pillar-desc">{p.description}</div>
                </div>
              ))}
            </div>
          )}

          <ul class="tier-features">
            {(tier.features as string[]).map(f => (
              <li>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>

          <a
            href={(tier.name === 'Enterprise' || tier.name === 'Custom') ? contactUrl : registerUrl}
            target="_blank"
            class={`tier-cta${tier.highlight ? ' tier-cta-primary' : ''}${tier.name === 'Enterprise' ? ' tier-cta-enterprise' : ''}${tier.name === 'Custom' ? ' tier-cta-custom' : ''}`}
          >
            {tier.price_monthly === 0 ? 'Start Free' : (tier.name === 'Enterprise' || tier.name === 'Custom') ? 'Contact Sales' : 'Get Started'}
          </a>
        </div>
      ))}
    </div>

    <!-- User roles add-on section -->
    <div class="roles-section reveal">
      <div class="roles-header">
        <div class="section-label">Team Access</div>
        <h2>Add users by role</h2>
        <p>Every plan includes 1 user. Add team members at a flat rate per role — applies to Pro, Enterprise, and Custom.</p>
      </div>
      <div class="roles-grid">
        {roles.map(role => (
          <div class="role-card">
            <div class="role-top-row">
              <div class="role-label">{role.label}</div>
              <div class="role-price">R{role.price_monthly}<span class="role-price-sub">/user/mo</span></div>
            </div>
            <div class="role-desc">{role.description}</div>
          </div>
        ))}
      </div>
      <p class="roles-note">Per user, per month. excl VAT. {data.annual_discount_percent}% discount on annual billing.</p>
    </div>

    <!-- Platform add-ons section -->
    <div class="addons-section reveal">
      <div class="addons-header">
        <div class="section-label">Add-Ons</div>
        <h2>Extend your platform</h2>
        <p>Available on Pro and Enterprise. Activate only what you need — charged per use, not per month.</p>
      </div>
      <div class="addons-grid">
        {addons.map((addon: any) => (
          <div class={`addon-card${addon.slug === 'advertising' ? ' addon-card-ads' : ''}`}>
            <div class="addon-top">
              <div class="addon-name">{addon.label}</div>
              <div class={`addon-price-pill${addon.slug === 'advertising' ? ' addon-price-pill-ads' : ''}`}>{addon.price_label}</div>
            </div>
            <p class="addon-desc">{addon.description}</p>

            {/* Ad formats — special layout for advertising add-on */}
            {addon.slug === 'advertising' && addon.ad_formats && (
              <div class="ad-formats">
                {(addon.ad_formats as any[]).map((fmt: any) => (
                  <div class="ad-format-item">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    <span>{fmt.label}</span>
                  </div>
                ))}
              </div>
            )}

            {/* Trust Account — layered wallet → invoicing → accounting layout */}
            {addon.slug === 'trust_account' && (
              <div class="wallet-layers">
                <div class="wallet-layer">
                  <div class="wallet-layer-title">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                    Trust Account
                  </div>
                  <div class="wallet-layer-desc">PPRA-compliant trust account — rent in, disbursements out, automated reconciliation</div>
                </div>
                <div class="wallet-layer-arrow">↓ unlocks</div>
                <div class="wallet-layer wallet-layer-accent">
                  <div class="wallet-layer-title">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                    Wallet
                  </div>
                  <div class="wallet-layer-desc">Organisation wallet — holds balances, splits commissions, runs marketplace earnings</div>
                </div>
                <div class="wallet-layer-arrow">↓ unlocks</div>
                <div class="wallet-layer">
                  <div class="wallet-layer-title">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    Invoicing
                  </div>
                  <div class="wallet-layer-desc">Rent, maintenance & commission invoices — auto-generated, PDF, tracked to paid</div>
                </div>
                <div class="wallet-layer-arrow">↓ unlocks</div>
                <div class="wallet-layer wallet-layer-accent">
                  <div class="wallet-layer-title">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    Accounting Write-Back
                  </div>
                  <div class="wallet-layer-desc">Auto-post to Xero, Sage, QuickBooks, or Pastel — VAT-aware, chart of accounts mapped</div>
                </div>
              </div>
            )}

            {/* Standard feature list */}
            {addon.slug !== 'advertising' && addon.slug !== 'trust_account' && (
              <ul class="addon-features">
                {(addon.features as string[]).map((f: string) => (
                  <li>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {f}
                  </li>
                ))}
              </ul>
            )}

            {/* Advertising: targeting + key features */}
            {addon.slug === 'advertising' && (
              <ul class="addon-features addon-features-sm">
                {(addon.features as string[]).map((f: string) => (
                  <li>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {f}
                  </li>
                ))}
              </ul>
            )}

            <div class="addon-note">{addon.price_note}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- API + MCP banner -->
    <div class="api-banner reveal">
      <div class="api-banner-inner">
        <div class="api-banner-text">
          <div class="api-badge">API + MCP</div>
          <h3>Build on Klikk. Included on all paid plans.</h3>
          <p>REST API and MCP server access included with every Pro and Enterprise account. Automate workflows, build integrations, or manage your portfolio directly from Claude.</p>
        </div>
        <div class="api-pills">
          <span class="api-pill">REST API</span>
          <span class="api-pill">MCP server</span>
          <span class="api-pill">Webhooks</span>
          <span class="api-pill">Claude integration</span>
        </div>
      </div>
    </div>

    <!-- Enterprise detail strip -->
    <div class="enterprise-strip reveal">
      <div class="ent-strip-inner">
        <div class="ent-strip-text">
          <div class="section-label" style="color: rgba(255,255,255,0.5)">Enterprise</div>
          <h2>Your brand. Your infrastructure.</h2>
          <p>White-label every client touchpoint — tenant app, owner portal, e-signing links, and admin dashboard. Deploy on Klikk's SA cloud or your own servers. Dedicated POPIA-compliant data environment included.</p>
        </div>
        <div class="ent-strip-pillars">
          <div class="ent-pillar">
            <div class="ent-pillar-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            </div>
            <div class="ent-pillar-title">White-Label</div>
            <div class="ent-pillar-desc">Client-facing portals and internal dashboard under your brand and domain</div>
          </div>
          <div class="ent-pillar">
            <div class="ent-pillar-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
            </div>
            <div class="ent-pillar-title">On or Off Premises</div>
            <div class="ent-pillar-desc">Klikk-managed cloud (SA-hosted) or deployed to your own infrastructure</div>
          </div>
          <div class="ent-pillar">
            <div class="ent-pillar-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div class="ent-pillar-title">POPIA Storage</div>
            <div class="ent-pillar-desc">Dedicated data environment — SA jurisdiction, isolated storage, full audit trail</div>
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <div class="faq-section reveal">
      <h2>Frequently asked questions</h2>
      <div class="faq-grid">
        <div class="faq-item">
          <h3>Is the free plan really free forever?</h3>
          <p>Yes. Up to 5 properties, 1 user, 2 AI-generated contracts, and AI maintenance reporting — free forever, no credit card. You supply your own LLM API key; Klikk never touches your AI costs on the free tier.</p>
        </div>
        <div class="faq-item">
          <h3>What does "bring your own LLM key" mean?</h3>
          <p>On the free tier you connect your own Claude or OpenAI API key. All AI features work — lease generation, maintenance AI, tenant chat — using your key, so you pay your provider directly. Paid plans include Klikk-managed AI at no extra charge.</p>
        </div>
        <div class="faq-item">
          <h3>What's the difference between properties and units?</h3>
          <p>A property is a physical address (e.g. a complex). A unit is an individual lettable space within it (e.g. Flat 3). Limits apply to whichever you reach first — 50 properties OR 100 units on Pro. Enterprise and Custom have no hard cap.</p>
        </div>
        <div class="faq-item">
          <h3>How does per-organisation pricing work?</h3>
          <p>One organisation, one flat monthly price — regardless of how many properties you have (up to the plan limit). No per-unit fees, no surprise billing.</p>
        </div>
        <div class="faq-item">
          <h3>Can I add more users?</h3>
          <p>Yes, on Pro, Enterprise, and Custom. Add team members at a flat rate per role: Viewer (R50), Agent (R90), or Admin (R150/user/month). The free tier is single-user only.</p>
        </div>
        <div class="faq-item">
          <h3>What's included in the Custom tier?</h3>
          <p>Everything in Enterprise plus a dedicated development engagement: custom integrations with your existing systems (ERP, CRM, legacy), a full Business Intelligence layer with custom dashboards, and ETL pipelines to your data warehouse (BigQuery, Snowflake, Redshift, SQL Server). Scoped and priced per project.</p>
        </div>
        <div class="faq-item">
          <h3>How do marketplace profits work?</h3>
          <p>Any commission you earn from marketplace transactions (electricity, internet, etc.) is yours — paid out as cash or applied as credits toward add-ons and plan upgrades. Available on the free tier too.</p>
        </div>
        <div class="faq-item">
          <h3>What does white-labelling include?</h3>
          <p>Everything tenant-facing and owner-facing: the tenant mobile app, owner portal, e-signing links, and the internal admin dashboard — all under your brand and domain.</p>
        </div>
        <div class="faq-item">
          <h3>What's the difference between on-premises and cloud hosting?</h3>
          <p>Cloud hosting is managed by Klikk on SA-based servers — fully POPIA compliant, zero infrastructure overhead. On-premises deploys Klikk to your own servers with our team handling setup and training.</p>
        </div>
        <div class="faq-item">
          <h3>What is the POPIA data storage fee?</h3>
          <p>Enterprise includes a dedicated, isolated data environment in South Africa — your data never shares infrastructure with other clients. Required for on-premises deployments. Quoted separately based on data volume and retention requirements.</p>
        </div>
        <div class="faq-item">
          <h3>Do you offer a discount for annual billing?</h3>
          <p>Yes — pay annually and get {data.annual_discount_percent}% off. Applies to Pro, Enterprise base, and all role add-ons.</p>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .pricing-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 40px 100px;
  }

  /* Hero */
  .pricing-hero {
    text-align: center;
    margin-bottom: 48px;
  }
  .pricing-hero h1 {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 800;
    color: var(--color-navy);
    letter-spacing: -2px;
    margin: 12px 0 16px;
    line-height: 1.08;
  }
  .pricing-hero p {
    font-size: 17px;
    color: #6b7280;
    line-height: 1.6;
  }

  /* All include row */
  .all-include {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px 20px;
    margin-bottom: 56px;
    padding: 14px 24px;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 12px;
  }
  .all-label {
    font-size: 12px;
    font-weight: 700;
    color: #059669;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-right: 4px;
  }
  .all-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-weight: 500;
    color: #047857;
  }
  .all-item svg { flex-shrink: 0; color: #059669; }

  /* Tier grid */
  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 80px;
    align-items: start;
  }
  .tiers-grid-4 {
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .tier-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 20px;
    padding: 36px 28px;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: box-shadow 0.25s, transform 0.25s;
  }
  .tier-card:hover {
    box-shadow: 0 8px 32px rgba(43,45,110,0.08);
    transform: translateY(-3px);
  }
  .tier-highlight {
    border-color: var(--color-navy);
    border-width: 2px;
    box-shadow: 0 4px 24px rgba(43,45,110,0.1);
  }
  .tier-highlight:hover {
    box-shadow: 0 12px 40px rgba(43,45,110,0.14);
  }
  .tier-enterprise {
    border-color: #e5e7eb;
    background: linear-gradient(145deg, #fafafa 0%, #f5f3ff 100%);
  }
  .tier-enterprise:hover {
    border-color: #c4b5fd;
    box-shadow: 0 8px 32px rgba(109,40,217,0.08);
  }

  .popular-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-navy);
    color: white;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 14px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .tier-top {
    margin-bottom: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid #f3f4f6;
  }
  .tier-name {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 4px;
  }
  .tier-enterprise .tier-name { color: #5b21b6; }
  .tier-subtitle {
    font-size: 13px;
    color: #9ca3af;
    margin-bottom: 16px;
    line-height: 1.4;
  }
  .tier-price {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 6px;
  }
  .price-amount {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 800;
    color: #111827;
    letter-spacing: -1.5px;
    line-height: 1;
  }
  .tier-highlight .price-amount { color: var(--color-navy); }
  .tier-enterprise .price-amount { color: #5b21b6; }
  .price-sub {
    font-size: 13px;
    color: #9ca3af;
    font-weight: 500;
  }

