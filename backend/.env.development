# ─── Django core ─────────────────────────────────────────────────────────────
# SECRET_KEY lives in .env.secrets — never committed
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────────────────────
# DB_PASSWORD lives in .env.secrets
DB_NAME=klikk_db
DB_USER=klikk_user
DB_HOST=localhost
DB_PORT=5432

# ─── Testing ─────────────────────────────────────────────────────────────────
USE_SQLITE_FOR_TESTS=True

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY lives in .env.secrets
ANTHROPIC_WEB_FETCH_ENABLED=true

# ─── PDF generation (Gotenberg) ──────────────────────────────────────────────
GOTENBERG_URL=http://localhost:3000

# ─── Google ──────────────────────────────────────────────────────────────────
# GOOGLE_OAUTH_CLIENT_ID and GOOGLE_MAPS_API_KEY live in .env.secrets — never committed

# ─── E-signing URLs ──────────────────────────────────────────────────────────
SIGNING_PUBLIC_APP_BASE_URL=http://localhost:5173
ESIGNING_WEBHOOK_PUBLIC_URL=http://localhost:8000

# ─── Email (console backend for dev — emails print to terminal) ───────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ─── Optional RAG / vector store ─────────────────────────────────────────────
# CONTRACT_DOCUMENTS_ROOT=/absolute/path/to/documents
# RAG_CHROMA_PATH=/absolute/path/to/rag_chroma
# RAG_QUERY_CHUNKS=8
# RAG_PDF_MAX_PAGES=120

# ─── Optional Twilio (SMS/OTP) ───────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=
