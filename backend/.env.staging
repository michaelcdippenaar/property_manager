# ─── Django core ─────────────────────────────────────────────────────────────
# SECRET_KEY lives in .env.secrets — never committed
DEBUG=False
ALLOWED_HOSTS=staging-api.klikk.co.za,api.klikk.co.za,backend.klikk.co.za,app.klikk.co.za,staging-app.klikk.co.za,staging-tenant.klikk.co.za,staging-mobile-agent.klikk.co.za,localhost,127.0.0.1

# ─── Test / debug endpoints ───────────────────────────────────────────────────
# Set to true only in staging to allow QA of ESigningTestPdfView and test-hub.
ENABLE_TEST_ENDPOINTS=True

# ─── Database ────────────────────────────────────────────────────────────────
# DB_PASSWORD lives in .env.secrets
DB_NAME=klikk_db
DB_USER=klikk_user
DB_HOST=db
DB_PORT=5432

# ─── Testing ─────────────────────────────────────────────────────────────────
USE_SQLITE_FOR_TESTS=False

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY lives in .env.secrets
ANTHROPIC_WEB_FETCH_ENABLED=false

# ─── PDF generation (Gotenberg) ──────────────────────────────────────────────
GOTENBERG_URL=http://gotenberg:3000

# ─── Google ──────────────────────────────────────────────────────────────────
# GOOGLE_OAUTH_CLIENT_ID and GOOGLE_MAPS_API_KEY live in .env.secrets — never committed

# ─── CORS / CSRF ─────────────────────────────────────────────────────────────
# Staging: allow both staging-* and production frontend origins so QA can test
# prod-linked flows without DNS switchover.
CORS_EXTRA_ORIGINS=https://staging-app.klikk.co.za,https://staging-tenant.klikk.co.za,https://staging-mobile-agent.klikk.co.za,https://app.klikk.co.za,https://tenant.klikk.co.za,https://mobile-agent.klikk.co.za,https://mobile-tenant.klikk.co.za,https://klikk.co.za,https://www.klikk.co.za
CSRF_TRUSTED_ORIGINS=https://staging-app.klikk.co.za,https://staging-tenant.klikk.co.za,https://staging-mobile-agent.klikk.co.za,https://staging-api.klikk.co.za,https://app.klikk.co.za,https://tenant.klikk.co.za,https://mobile-agent.klikk.co.za,https://mobile-tenant.klikk.co.za,https://agent.klikk.co.za,https://api.klikk.co.za,https://backend.klikk.co.za

# ─── E-signing URLs ──────────────────────────────────────────────────────────
SIGNING_PUBLIC_APP_BASE_URL=https://staging-app.klikk.co.za
ESIGNING_WEBHOOK_PUBLIC_URL=https://staging-api.klikk.co.za

# ─── Email (AWS SES SMTP — af-south-1) ───────────────────────────────────────
# EMAIL_HOST_USER and EMAIL_HOST_PASSWORD come from SSM Parameter Store at boot.
# Retrieve via: aws ssm get-parameter --name /klikk/staging/ses/smtp-user --with-decryption
# and:          aws ssm get-parameter --name /klikk/staging/ses/smtp-password --with-decryption
# Then export as EMAIL_HOST_USER / EMAIL_HOST_PASSWORD in the environment or add to .env.secrets.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=email-smtp.af-south-1.amazonaws.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# EMAIL_HOST_USER=<from SSM /klikk/staging/ses/smtp-user>         ← .env.secrets
# EMAIL_HOST_PASSWORD=<from SSM /klikk/staging/ses/smtp-password> ← .env.secrets
DEFAULT_FROM_EMAIL=Klikk Staging <no-reply@klikk.co.za>
SERVER_EMAIL=no-reply@klikk.co.za
EMAIL_REPLY_TO=support@klikk.co.za
AWS_SES_REGION=af-south-1
# VOLT_MCP (VOLT_OWNER_API_KEY) lives in .env.secrets — never committed

# ─── Backups ─────────────────────────────────────────────────────────────────
# Non-secret backup config for staging (secrets live in .env.secrets).
# Bucket name is env-driven: staging → klikk-backups-af, prod → klikk-backups-af-prod
# Override BACKUP_S3_BUCKET in .env.secrets on production servers.
DEPLOY_ENV=staging
BACKUP_S3_BUCKET=klikk-backups-af
BACKUP_S3_PREFIX=klikk-staging
BACKUP_AWS_REGION=af-south-1
