# ─── Django core ─────────────────────────────────────────────────────────────
# SECRET_KEY lives in .env.secrets — never committed
DEBUG=False
ALLOWED_HOSTS=backend.klikk.co.za,localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────────────────────
# DB_PASSWORD lives in .env.secrets
DB_NAME=klikk_db
DB_USER=klikk_user
DB_HOST=db
DB_PORT=5432

# ─── Testing ─────────────────────────────────────────────────────────────────
USE_SQLITE_FOR_TESTS=False

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY lives in .env.secrets
ANTHROPIC_WEB_FETCH_ENABLED=false

# ─── PDF generation (Gotenberg) ──────────────────────────────────────────────
GOTENBERG_URL=http://gotenberg:3000

# ─── Google ──────────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=463351671420-7hh3aln6nc6s5vi6ds9huka21cphp9h1.apps.googleusercontent.com
GOOGLE_MAPS_API_KEY=AIzaSyAKdTBybb8R0xC-NldeUsjgRve7kDs5RZY

# ─── E-signing URLs ──────────────────────────────────────────────────────────
SIGNING_PUBLIC_APP_BASE_URL=https://app.klikk.co.za
ESIGNING_WEBHOOK_PUBLIC_URL=https://backend.klikk.co.za

# ─── Email (Gmail SMTP) ──────────────────────────────────────────────────────
# EMAIL_HOST_PASSWORD lives in .env.secrets
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
