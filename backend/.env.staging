# ─── Django core ─────────────────────────────────────────────────────────────
# SECRET_KEY lives in .env.secrets — never committed
DEBUG=False
ALLOWED_HOSTS=backend.klikk.co.za,app.klikk.co.za,localhost,127.0.0.1

# ─── Test / debug endpoints ───────────────────────────────────────────────────
# Set to true only in staging to allow QA of ESigningTestPdfView and test-hub.
ENABLE_TEST_ENDPOINTS=True

# ─── Database ────────────────────────────────────────────────────────────────
# DB_PASSWORD lives in .env.secrets
DB_NAME=klikk_db
DB_USER=klikk_user
DB_HOST=db
DB_PORT=5432

# ─── Testing ─────────────────────────────────────────────────────────────────
USE_SQLITE_FOR_TESTS=False

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY lives in .env.secrets
ANTHROPIC_WEB_FETCH_ENABLED=false

# ─── PDF generation (Gotenberg) ──────────────────────────────────────────────
GOTENBERG_URL=http://gotenberg:3000

# ─── Google ──────────────────────────────────────────────────────────────────
# GOOGLE_OAUTH_CLIENT_ID and GOOGLE_MAPS_API_KEY live in .env.secrets — never committed

# ─── CORS / CSRF ─────────────────────────────────────────────────────────────
CORS_EXTRA_ORIGINS=https://app.klikk.co.za,https://admin.klikk.co.za,https://register.klikk.co.za,https://www.klikk.co.za
CSRF_TRUSTED_ORIGINS=https://app.klikk.co.za,https://admin.klikk.co.za,https://register.klikk.co.za,https://www.klikk.co.za,https://backend.klikk.co.za

# ─── E-signing URLs ──────────────────────────────────────────────────────────
SIGNING_PUBLIC_APP_BASE_URL=https://app.klikk.co.za
ESIGNING_WEBHOOK_PUBLIC_URL=https://backend.klikk.co.za

# ─── Email (Gmail SMTP) ──────────────────────────────────────────────────────
# EMAIL_HOST_PASSWORD lives in .env.secrets
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=michael.c.dippenaar@gmail.com
DEFAULT_FROM_EMAIL=Klikk <michael.c.dippenaar@gmail.com>
# VOLT_MCP (VOLT_OWNER_API_KEY) lives in .env.secrets — never committed

# ─── Backups ─────────────────────────────────────────────────────────────────
# Non-secret backup config for staging (secrets live in .env.secrets).
# Bucket name is env-driven: staging → klikk-backups-af, prod → klikk-backups-af-prod
# Override BACKUP_S3_BUCKET in .env.secrets on production servers.
BACKUP_S3_BUCKET=klikk-backups-af
BACKUP_S3_PREFIX=klikk-staging
BACKUP_AWS_REGION=af-south-1
