# ─── Django core ─────────────────────────────────────────────────────────────
# SECRET_KEY lives in .env.secrets — never committed
DEBUG=False
ALLOWED_HOSTS=api.klikk.co.za,backend.klikk.co.za,app.klikk.co.za,tenant.klikk.co.za,mobile-agent.klikk.co.za,mobile-tenant.klikk.co.za,agent.klikk.co.za

# ─── Test / debug endpoints ───────────────────────────────────────────────────
# MUST remain False in production. Enables ESigningTestPdfView and test-hub URLs.
ENABLE_TEST_ENDPOINTS=False

# ─── Database ────────────────────────────────────────────────────────────────
# DB_PASSWORD lives in .env.secrets
DB_NAME=klikk_db
DB_USER=klikk_user
DB_HOST=db
DB_PORT=5432

# ─── Testing ─────────────────────────────────────────────────────────────────
USE_SQLITE_FOR_TESTS=False

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY lives in .env.secrets
ANTHROPIC_WEB_FETCH_ENABLED=false

# ─── PDF generation (Gotenberg) ──────────────────────────────────────────────
GOTENBERG_URL=http://gotenberg:3000

# ─── Google ──────────────────────────────────────────────────────────────────
# GOOGLE_OAUTH_CLIENT_ID and GOOGLE_MAPS_API_KEY live in .env.secrets — never committed

# ─── CORS / CSRF ─────────────────────────────────────────────────────────────
CORS_EXTRA_ORIGINS=https://app.klikk.co.za,https://agent.klikk.co.za,https://tenant.klikk.co.za,https://mobile-agent.klikk.co.za,https://mobile-tenant.klikk.co.za,https://klikk.co.za,https://www.klikk.co.za
CSRF_TRUSTED_ORIGINS=https://app.klikk.co.za,https://agent.klikk.co.za,https://tenant.klikk.co.za,https://mobile-agent.klikk.co.za,https://mobile-tenant.klikk.co.za,https://api.klikk.co.za,https://backend.klikk.co.za

# ─── E-signing URLs ──────────────────────────────────────────────────────────
SIGNING_PUBLIC_APP_BASE_URL=https://app.klikk.co.za
ESIGNING_WEBHOOK_PUBLIC_URL=https://api.klikk.co.za

# ─── Email (AWS SES SMTP — af-south-1) ───────────────────────────────────────
# EMAIL_HOST_USER and EMAIL_HOST_PASSWORD come from SSM Parameter Store at boot.
# Retrieve via: aws ssm get-parameter --name /klikk/production/ses/smtp-user --with-decryption
# and:          aws ssm get-parameter --name /klikk/production/ses/smtp-password --with-decryption
# Then export as EMAIL_HOST_USER / EMAIL_HOST_PASSWORD in the environment or add to .env.secrets.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=email-smtp.af-south-1.amazonaws.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# EMAIL_HOST_USER=<from SSM /klikk/production/ses/smtp-user>         ← .env.secrets
# EMAIL_HOST_PASSWORD=<from SSM /klikk/production/ses/smtp-password> ← .env.secrets
DEFAULT_FROM_EMAIL=Klikk <no-reply@klikk.co.za>
SERVER_EMAIL=no-reply@klikk.co.za
EMAIL_REPLY_TO=support@klikk.co.za
AWS_SES_REGION=af-south-1

# ─── Backups ─────────────────────────────────────────────────────────────────
# Non-secret backup config for production (secrets live in .env.secrets).
DEPLOY_ENV=production
BACKUP_S3_BUCKET=klikk-backups-af-prod
BACKUP_S3_PREFIX=klikk-production
BACKUP_AWS_REGION=af-south-1
# Dead-man's switch: heartbeat URL pinged after every successful S3 upload.
# Create a "Heartbeat" monitor in UptimeRobot (or use healthchecks.io) with a
# 26-hour window and paste the ping URL here.  Leave blank to disable.
# BACKUP_HEARTBEAT_URL=https://heartbeat.uptimerobot.com/...
