SECRET_KEY=your-secret-key-here
DEBUG=True
# Enable test/debug endpoints (ESigningTestPdfView, test-hub).
# Set to true ONLY in local dev or staging — MUST be false in production.
ENABLE_TEST_ENDPOINTS=True
# For Flutter on a physical phone, add your Mac's LAN IP (same Wi‑Fi) and run:
#   python manage.py runserver 0.0.0.0:8000
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.42

DB_NAME=klikk_db
DB_USER=klikk_user
DB_PASSWORD=klikk_pass
DB_HOST=localhost
DB_PORT=5432

ANTHROPIC_API_KEY=your-anthropic-api-key

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=

# Agent assist: vectorized leases / house rules under backend/documents (or override path)
# CONTRACT_DOCUMENTS_ROOT=/absolute/path/to/documents
# RAG_CHROMA_PATH=/absolute/path/to/rag_chroma
# RAG_QUERY_CHUNKS=8
# RAG_PDF_MAX_PAGES=120

# Optional: Anthropic web_fetch for agent-assist (URLs must appear in the chat)
ANTHROPIC_WEB_FETCH_ENABLED=false

# Gotenberg — HTML→PDF via Chromium (docker compose up -d gotenberg)
GOTENBERG_URL=http://localhost:3000

# ── Email (apps.notifications) — dev: leave EMAIL_BACKEND as console (default in code) or omit
# Gmail: 2FA + App password → https://myaccount.google.com/apppasswords
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=your16charapppassword
# DEFAULT_FROM_EMAIL=You <you@gmail.com>

# Optional: Twilio for SMS/WhatsApp (see apps/notifications/NOTIFICATIONS.md)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=

# Tenant web-app base URL — used to build /invite/<token> links in tenant invite emails.
# In dev, leave blank to use default http://localhost:5174. Set in production.
# TENANT_APP_BASE_URL=https://app.klikk.co.za

# ── Sentry — error monitoring (leave blank in dev to skip) ──────────────────
# Create three projects in Sentry: klikk-backend-dev, klikk-backend-staging, klikk-backend-prod
# SENTRY_DSN=https://<key>@oXXXXXX.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.05
# GIT_COMMIT is injected by CI (git rev-parse --short HEAD); leave blank locally
