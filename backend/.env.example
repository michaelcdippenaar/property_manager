SECRET_KEY=your-secret-key-here
DEBUG=True
# For Flutter on a physical phone, add your Mac's LAN IP (same Wi‑Fi) and run:
#   python manage.py runserver 0.0.0.0:8000
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.42

DB_NAME=klikk_db
DB_USER=klikk_user
DB_PASSWORD=klikk_pass
DB_HOST=localhost
DB_PORT=5432

ANTHROPIC_API_KEY=your-anthropic-api-key

# Agent assist: vectorized leases / house rules under backend/documents (or override path)
# CONTRACT_DOCUMENTS_ROOT=/absolute/path/to/documents
# RAG_CHROMA_PATH=/absolute/path/to/rag_chroma
# RAG_QUERY_CHUNKS=8
# RAG_PDF_MAX_PAGES=120

# Optional: Anthropic web_fetch for agent-assist (URLs must appear in the chat)
ANTHROPIC_WEB_FETCH_ENABLED=false

# DocuSeal — API base must match where you copied DOCUSEAL_API_KEY from.
# Cloud (US): https://api.docuseal.com   EU: https://api.docuseal.eu
# Self-hosted: use your public origin + /api (code calls /templates/pdf, /submissions)
# DOCUSEAL_API_URL=https://api.docuseal.com
# DOCUSEAL_API_URL=https://signing.example.com/api
# Local docker (repo root docker-compose.docuseal.yml): http://127.0.0.1:3000/api
# Note: free self-hosted omits POST /templates/pdf; Pro unlocks it (same paths as cloud).
DOCUSEAL_API_URL=https://api.docuseal.com
DOCUSEAL_API_KEY=your-docuseal-api-key
# Optional bookmark: DocuSeal “Webhooks” screen (e.g. https://signing.example.com/hooks). Not used in HTTP code.
# DOCUSEAL_HOOK_URL=https://signing.example.com/hooks
# Public API origin only (HTTPS, no path) — used for GET /esigning/webhook/info/ copy-paste URL.
# ESIGNING_WEBHOOK_PUBLIC_URL=https://api.example.com
# If DocuSeal “Add secret” sends a custom header = secret value (not HMAC), set the header name:
# DOCUSEAL_WEBHOOK_HEADER_NAME=X-Webhook-Secret
# Receiver URL to paste *into* DocuSeal: {ESIGNING_WEBHOOK_PUBLIC_URL}/api/v1/esigning/webhook/
DOCUSEAL_WEBHOOK_SECRET=your-webhook-secret

# ── Email (apps.notifications) — dev: leave EMAIL_BACKEND as console (default in code) or omit
# Gmail: 2FA + App password → https://myaccount.google.com/apppasswords
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=your16charapppassword
# DEFAULT_FROM_EMAIL=You <you@gmail.com>

# Optional: Twilio for SMS/WhatsApp (see apps/notifications/NOTIFICATIONS.md)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=
