# ─────────────────────────────────────────────────────────────────────────────
#  backend/.env.secrets  —  NEVER commit the filled copy to git
# ─────────────────────────────────────────────────────────────────────────────
#  Copy this file to backend/.env.secrets and fill in the real values.
#  Store the filled copy in Bitwarden under "Klikk → Staging secrets".
#
#  Generate SECRET_KEY:
#    python -c "from django.utils.crypto import get_random_string; print(get_random_string(50))"
# ─────────────────────────────────────────────────────────────────────────────

SECRET_KEY=
# DB_PASSWORD   — used by the Django backend to connect to Postgres
DB_PASSWORD=
# POSTGRES_PASSWORD — must match DB_PASSWORD; used by the Postgres container itself
POSTGRES_PASSWORD=
ANTHROPIC_API_KEY=
EMAIL_HOST_PASSWORD=

# ─── Google (OAuth + Maps) ───────────────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_MAPS_API_KEY=

# ─── Volt MCP owner key ──────────────────────────────────────────────────────
# Generate with: python manage.py volt_create_owner_key
# Must also be set as VOLT_OWNER_API_KEY in docker-compose environment
VOLT_MCP=
VOLT_OWNER_API_KEY=

# ─── Backups ─────────────────────────────────────────────────────────────────
# See docs/ops/backup-restore.md for setup instructions.
# IAM user klikk-backup (write + list, no delete) — from Bitwarden "Klikk → Backup IAM credentials"
BACKUP_S3_BUCKET=klikk-backups-af
BACKUP_S3_PREFIX=klikk-production          # or klikk-staging
AWS_DEFAULT_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# age recipient public key — from Bitwarden "Klikk → Backup age private key"
AGE_PUBLIC_KEY=
# Alert channels (at least one strongly recommended)
SLACK_WEBHOOK_URL=
ALERT_EMAIL=

# Optional — uncomment when Twilio is configured
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=

# Optional — uncomment to enable Caddy basic-auth on staging
# BASIC_AUTH_USER=
# BASIC_AUTH_HASH=
