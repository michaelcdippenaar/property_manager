# Plausible CE secrets — copy to env.plausible and fill in values.
# Never commit env.plausible.
#
# SECRET_KEY_BASE (64-byte):  openssl rand -base64 64 | tr -d '\n'
# TOTP_VAULT_KEY  (32-byte):  openssl rand -base64 32 | tr -d '\n'
# DATABASE_URL password:      same POSTGRES_PASSWORD as in backend/.env.secrets

BASE_URL=https://analytics.klikk.co.za
SECRET_KEY_BASE=
TOTP_VAULT_KEY=
DATABASE_URL=postgres://klikk_user:<password>@db:5432/plausible
CLICKHOUSE_DATABASE_URL=http://plausible_events_db:8123/plausible_events_db
DISABLE_REGISTRATION=invite_only
