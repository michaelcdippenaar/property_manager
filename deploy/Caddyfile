{
  # Email used for Let's Encrypt account (optional but recommended)
  email admin@klikk.co.za
}

(no_index_headers) {
  header {
    X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "no-referrer"
  }
}

(optional_basic_auth) {
  # If BASIC_AUTH_USER/HASH are empty, this directive will error.
  # Keep them set in production if you truly want "no Google detection".
  basicauth {
    {$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
  }
}

# Marketing site (public — no Basic Auth; optional noindex headers only)
klikk.co.za {
  redir https://www.klikk.co.za{uri} permanent
}

www.klikk.co.za {
  import no_index_headers
  reverse_proxy website_web:80
}

# Admin SPA (public login)
app.klikk.co.za {
  import no_index_headers

  # CSP for the static SPA shell.  No nonce is needed here because the Vite
  # build emits zero inline scripts — only <script type="module" src="...">
  # external tags.  'self' therefore covers all module scripts without
  # 'strict-dynamic' (which would incorrectly shadow 'self').
  # Django-side SecurityHeadersMiddleware keeps its own nonce for rendered
  # pages; this header applies only to the Caddy-served SPA origin.
  header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://api.klikk.co.za https://backend.klikk.co.za; media-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"

  # Proxy media requests to backend
  handle /media/* {
    reverse_proxy backend:8000
  }

  # SPA routes
  reverse_proxy admin_web:80
}

# Django API + Volt MCP
# /mcp/ → volt_mcp:8765 (owner MCP server, bearer-token auth)
# everything else → backend:8000 (Django REST API)
backend.klikk.co.za {
  # Volt Owner MCP — streamable HTTP endpoint
  handle /mcp/* {
    reverse_proxy volt_mcp:8765 {
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-For {remote_host}
      header_up X-Forwarded-Proto {scheme}

      # Streamable HTTP uses long-lived connections — disable buffering
      flush_interval -1
    }
  }

  # Main Django API proxy — generous timeouts for AI endpoints
  # (parse-document, ai-chat, builder sessions can take 60-120s)
  reverse_proxy backend:8000 {
    transport http {
      read_timeout 180s
      write_timeout 180s
    }
  }
}

# Agent mobile web (Quasar SPA)
mobile-agent.klikk.co.za {
  import no_index_headers

  # Same static-SPA CSP rationale as app.klikk.co.za above.
  header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://api.klikk.co.za https://backend.klikk.co.za; media-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"

  reverse_proxy agent_app_web:80
}
