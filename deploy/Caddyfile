# Staging Django API
staging-api.klikk.co.za {
  import hsts_header
  import no_index_headers

  # Lease AI v2 streaming endpoint — disable Caddy buffering so SSE
  # events flush to the browser as the pipeline emits them. Mirrors the
  # api.klikk.co.za block. Per docs/system/lease-ai-asgi-decision.md
  # Option D. Must come BEFORE the unscoped default proxy.
  handle /api/v1/leases/templates/*/ai-chat-v2/* {
    reverse_proxy staging_backend:8000 {
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-For {remote_host}
      header_up X-Forwarded-Proto {scheme}

      flush_interval -1

      transport http {
        read_timeout 180s
        write_timeout 180s
      }
    }
  }

  reverse_proxy staging_backend:8000 {
    transport http {
      read_timeout 180s
      write_timeout 180s
    }
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# VAULT33 — staging (separate codebase, same host)
# Backend: vault33-staging-backend:8000  Frontend (Vite): vault33-staging-frontend:5180
# Caddy must be attached to network `vault33-staging_default` for names to resolve.
# ─────────────────────────────────────────────────────────────────────────────

# Vault33 owner SPA
app.vault33.co.za {
  import hsts_header
  import no_index_headers

  handle /api/* {
    reverse_proxy vault33-staging-backend:8000 {
      transport http {
        read_timeout 180s
        write_timeout 180s
      }
    }
  }
  handle /admin/* {
    reverse_proxy vault33-staging-backend:8000
  }
  handle /media/* {
    reverse_proxy vault33-staging-backend:8000
  }
  handle /static/* {
    reverse_proxy vault33-staging-backend:8000
  }

  reverse_proxy vault33-staging-frontend:5180
}

# Vault33 public share endpoint (outbound share recipients + inbound upload pages)
share.vault33.co.za {
  import hsts_header
  import no_index_headers

  handle /api/* {
    reverse_proxy vault33-staging-backend:8000
  }
  handle /media/* {
    reverse_proxy vault33-staging-backend:8000
  }

  reverse_proxy vault33-staging-frontend:5180
}
