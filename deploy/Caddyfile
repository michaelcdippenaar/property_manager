{
  # Email used for Let's Encrypt account (optional but recommended)
  email admin@klikk.co.za
}

(no_index_headers) {
  header {
    X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "no-referrer"
  }
}

(optional_basic_auth) {
  # If BASIC_AUTH_USER/HASH are empty, this directive will error.
  # Keep them set in production if you truly want "no Google detection".
  basicauth {
    {$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
  }
}

# Marketing site (public — no Basic Auth; optional noindex headers only)
klikk.co.za {
  redir https://www.klikk.co.za{uri} permanent
}

www.klikk.co.za {
  import no_index_headers
  reverse_proxy website_web:80
}

# Admin SPA (public login)
app.klikk.co.za {
  import no_index_headers
  
  # Proxy media requests to backend
  handle /media/* {
    reverse_proxy backend:8000
  }
  
  # SPA routes
  reverse_proxy admin_web:80
}

# Django API + Volt MCP
# /mcp/ → volt_mcp:8765 (owner MCP server, bearer-token auth)
# everything else → backend:8000 (Django REST API)
backend.klikk.co.za {
  # Volt Owner MCP — streamable HTTP endpoint
  handle /mcp/* {
    reverse_proxy volt_mcp:8765 {
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-For {remote_host}
      header_up X-Forwarded-Proto {scheme}

      # Streamable HTTP uses long-lived connections — disable buffering
      flush_interval -1
    }
  }
  
  # Main Django API proxy — generous timeouts for AI endpoints
  # (parse-document, ai-chat, builder sessions can take 60-120s)
  reverse_proxy backend:8000 {
    transport http {
      read_timeout 180s
      write_timeout 180s
    }
  }
}

# Agent mobile web (Quasar SPA)
mobile-agent.klikk.co.za {
  import no_index_headers
  reverse_proxy agent_app_web:80
}

