# Django API + Volt MCP
# /mcp/ → volt_mcp:8765 (owner MCP server, bearer-token auth)
# everything else → backend:8000 (Django REST API)
api.klikk.co.za {
  import hsts_header

  # Volt Owner MCP — streamable HTTP endpoint
  handle /mcp/* {
    reverse_proxy volt_mcp:8765 {
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-For {remote_host}
      header_up X-Forwarded-Proto {scheme}

      # Streamable HTTP uses long-lived connections — disable buffering
      flush_interval -1
    }
  }

  # Lease AI v2 streaming endpoint — disable Caddy buffering so SSE
  # events flush to the browser as the pipeline emits them. Matches the
  # Volt MCP pattern above. Per docs/system/lease-ai-asgi-decision.md
  # Option D. Must come BEFORE the unscoped default proxy so `handle`
  # short-circuits the trailing block.
  handle /api/v1/leases/templates/*/ai-chat-v2/* {
    reverse_proxy backend:8000 {
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-For {remote_host}
      header_up X-Forwarded-Proto {scheme}

      flush_interval -1

      transport http {
        read_timeout 180s
        write_timeout 180s
      }
    }
  }

  # Main Django API proxy — generous timeouts for AI endpoints
  # (parse-document, ai-chat, builder sessions can take 60-120s)
  reverse_proxy backend:8000 {
    transport http {
      read_timeout 180s
      write_timeout 180s
    }
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# STAGING — virtual hosts (same EC2, staging Docker Compose profile / ports)
# Staging services bind on different host ports; Caddy routes to them by
# upstream name. Uses the same Let's Encrypt ACME flow — valid TLS on day one.
# Staging subdomains are noindex + carry the same HSTS as prod so the header
# is consistent, but HSTS preload is only submitted for prod surfaces.
# ─────────────────────────────────────────────────────────────────────────────

# Staging admin SPA
staging-app.klikk.co.za {
  import hsts_header
  import no_index_headers

  header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://staging-api.klikk.co.za; media-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"

  handle /media/* {
    reverse_proxy staging_backend:8000
  }

  reverse_proxy staging_admin_web:80
}

