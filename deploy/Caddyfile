{
  # Email used for Let's Encrypt account
  email admin@klikk.co.za
}

(no_index_headers) {
  header {
    X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "no-referrer"
  }
}

(hsts_header) {
  header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
}

(optional_basic_auth) {
  # If BASIC_AUTH_USER/HASH are empty, this directive will error.
  # Keep them set in production if you truly want "no Google detection".
  basicauth {
    {$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# REDIRECTS
# ─────────────────────────────────────────────────────────────────────────────

# www → apex (permanent)
www.klikk.co.za {
  import hsts_header
  redir https://klikk.co.za{uri} permanent
}

# agent. → app. (sunset redirect — remove after 90 days of app. stability)
agent.klikk.co.za {
  import hsts_header
  redir https://app.klikk.co.za{uri} permanent
}

# backend. → api. (sunset redirect — remove after 90 days)
backend.klikk.co.za {
  import hsts_header
  redir https://api.klikk.co.za{uri} permanent
}

# Staging redirect aliases (mirror the pattern for consistency)
staging-www.klikk.co.za {
  import hsts_header
  import no_index_headers
  redir https://staging-app.klikk.co.za{uri} permanent
}

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION — canonical virtual hosts
# ─────────────────────────────────────────────────────────────────────────────

# Marketing site (Astro static build)
klikk.co.za {
  import hsts_header

  # CSP for static marketing site — allows Google Fonts, analytics, etc.
  header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://plausible.klikk.co.za; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://plausible.klikk.co.za https://api.klikk.co.za; media-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"

  reverse_proxy website_web:80
}

# Admin SPA (Vue 3, admin/)
app.klikk.co.za {
  import hsts_header
  import no_index_headers

  # CSP for the static SPA shell. No nonce needed — Vite build emits only
  # <script type="module" src="..."> external tags. 'self' covers all module
  # scripts. Django SecurityHeadersMiddleware keeps its own nonce for rendered
  # pages; this header applies only to the Caddy-served SPA origin.
  header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://api.klikk.co.za https://backend.klikk.co.za; media-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"

  # Proxy media requests to backend
  handle /media/* {
    reverse_proxy backend:8000
  }

  # SPA routes
  reverse_proxy admin_web:80
}

# Tenant web app (web_app/)
tenant.klikk.co.za {
  import hsts_header
  import no_index_headers

  header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://api.klikk.co.za; media-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"

  # Proxy media requests to backend
  handle /media/* {
    reverse_proxy backend:8000
  }

  reverse_proxy tenant_web:80
}

